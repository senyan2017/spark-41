#!/usr/bin/env bash
#
# spark
# https://github.com/holman/spark
#
# Generates sparklines for a set of data.
#
# Here's a good web-based sparkline generator that was a bit of inspiration
# for spark:
#
#   https://datacollective.org/sparkblocks
#
# spark takes a comma-separated or space-separated list of data and then prints
# a sparkline out of it.
#
# Examples:
#
#   spark 1 5 22 13 53
#   # => ‚ĖĀ‚ĖĀ‚ĖÉ‚Ėā‚Ėá
#
#   spark 0 30 55 80 33 150
#   # => ‚ĖĀ‚Ėā‚ĖÉ‚ĖÖ‚Ėā‚Ėá
#
#   spark -h
#   # => Prints the spark help text.

# Generates sparklines.
#
# $1 - The data we'd like to graph.
_echo()
{
  if [ "X$1" = "X-n" ]; then
    shift
    printf "%s" "$*"
  else
    printf "%s\n" "$*"
  fi
}

spark()
{
  local n numbers= min= max=

  # Bash has no floating-point arithmetic, so we work in fixed-point: every
  # value is parsed into an integer scaled by 10^scale_digits. This keeps
  # fractional differences (e.g. 0.4 vs 0.9) instead of truncating the decimal
  # part away, while the tick math below stays scale-invariant for integers so
  # existing whole-number graphs are unchanged.
  local scale_digits=3
  local scale=$(( 10 ** scale_digits ))

  # A valid value is an optionally-signed integer or decimal: 5, -3, +7, 0.4,
  # 5.5, .5 or 3. -- anything else (abc, 1e3, 1.2.3) is rejected below.
  local re='^[+-]?([0-9]+\.?[0-9]*|\.[0-9]+)$'

  # Parse, validate and scale each value while tracking the real min/max.
  # Splitting on whitespace already drops empty fields produced by repeated or
  # trailing separators (e.g. "1,,2," -> 1 2), so those are ignored silently.
  for n in ${@//,/ }
  do
    [ -z "$n" ] && continue

    if [[ ! $n =~ $re ]]; then
      printf "spark: invalid value: '%s' (expected a number like 5, -3 or 0.4)\n" "$n" >&2
      return 1
    fi

    # Convert the decimal string to a scaled integer (value * scale).
    local sign=1 int frac
    case $n in
      -*) sign=-1; n=${n#-} ;;
      +*) n=${n#+} ;;
    esac
    int=${n%%.*}
    if [[ $n == *.* ]]; then frac=${n#*.}; else frac=; fi
    int=${int:-0}
    # Right-pad the fraction with zeros, then keep scale_digits of precision.
    frac=${frac}0000000000
    frac=${frac:0:scale_digits}
    # Force base-10 (10#) so leading zeros are not read as octal.
    n=$(( (10#$int * scale + 10#$frac) * sign ))

    if [ -z "$min" ]; then
      min=$n max=$n
    else
      (( n < min )) && min=$n
      (( n > max )) && max=$n
    fi
    numbers=$numbers${numbers:+ }$n
  done

  # Refuse to draw anything if no usable numbers were given (e.g. the input was
  # only blanks or separators) rather than printing a misleading graph.
  if [ -z "$numbers" ]; then
    printf "spark: no numeric data provided\n" >&2
    return 1
  fi

  # print ticks
  local ticks=(‚ĖĀ ‚Ėā ‚ĖÉ ‚ĖĄ ‚ĖÖ ‚ĖÜ ‚Ėá ‚Ėą)

  # use a high tick if data is constant
  (( min == max )) && ticks=(‚ĖÖ ‚ĖÜ)

  local f=$(( (($max-$min)<<8)/(${#ticks[@]}-1) ))
  (( f < 1 )) && f=1

  for n in $numbers
  do
    _echo -n ${ticks[$(( ((($n-$min)<<8)/$f) ))]}
  done
  _echo
}

# If we're being sourced, don't worry about such things
if [ "$BASH_SOURCE" == "$0" ]; then
  # Prints the help text for spark.
  help()
  {
    local spark=$(basename $0)
    cat <<EOF

    USAGE:
      $spark [-h|--help] VALUE,...

    EXAMPLES:
      $spark 1 5 22 13 53
      ‚ĖĀ‚ĖĀ‚ĖÉ‚Ėā‚Ėą
      $spark 0,30,55,80,33,150
      ‚ĖĀ‚Ėā‚ĖÉ‚ĖĄ‚Ėā‚Ėą
      echo 9 13 5 17 1 | $spark
      ‚ĖĄ‚ĖÜ‚Ėā‚Ėą‚ĖĀ
      $spark -8 -3 -5 -1
      ‚ĖĀ‚ĖÜ‚ĖĄ‚Ėą
      $spark 0.4 0.5 0.9
      ‚ĖĀ‚Ėā‚Ėą

    NOTES:
      Values are separated by commas or whitespace. Negative numbers and
      decimals are fully supported: the ticks span the range between the
      smallest and largest value, so an all-negative series (e.g. -8 -3 -1)
      is graphed correctly and decimals such as 0.4 and 0.9 stay distinct
      instead of collapsing to the same height.

      Empty fields from repeated or trailing separators are ignored, so
      "1,,2," is read as "1 2". A non-numeric value (e.g. "abc" or "1e3")
      is reported as an error and no graph is drawn, rather than being
      silently treated as zero.
EOF
  }

  # show help for no arguments if stdin is a terminal
  if { [ -z "$1" ] && [ -t 0 ] ; } || [ "$1" == '-h' ] || [ "$1" == '--help' ]
  then
    help
    exit 0
  fi

  spark ${@:-`cat`}
fi
