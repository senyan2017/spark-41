#!/usr/bin/env bash
#
# spark
# https://github.com/holman/spark
#
# Generates sparklines for a set of data.
#
# Here's a good web-based sparkline generator that was a bit of inspiration
# for spark:
#
#   https://datacollective.org/sparkblocks
#
# spark takes a comma-separated or space-separated list of data and then prints
# a sparkline out of it.
#
# Examples:
#
#   spark 1 5 22 13 53
#   # => ▁▁▃▂▇
#
#   spark 0 30 55 80 33 150
#   # => ▁▂▃▅▂▇
#
#   spark -5 -3 -1 0 2
#   # => ▁▃▅▆█
#
#   spark 0.1 0.5 0.9
#   # => ▁▄█
#
#   spark -h
#   # => Prints the spark help text.

# Generates sparklines.
#
# $1 - The data we'd like to graph.
spark()
{
  printf '%s\n' "${*//,/ }" | awk '
  BEGIN {
    ticks[1] = "▁"; ticks[2] = "▂"; ticks[3] = "▃"; ticks[4] = "▄"
    ticks[5] = "▅"; ticks[6] = "▆"; ticks[7] = "▇"; ticks[8] = "█"
    num_ticks = 8
    count = 0
  }
  {
    n = split($0, raw)
    for (i = 1; i <= n; i++) {
      val = raw[i]
      # Skip empty fields
      if (val == "") continue
      # Validate numeric input: optional minus, digits, optional decimal part
      if (val !~ /^-?[0-9]*\.?[0-9]+$/) {
        printf "spark: error: \"%s\" is not a valid number\n", val > "/dev/stderr"
        continue
      }
      count++
      nums[count] = val + 0
      if (count == 1) {
        min = nums[1]
        max = nums[1]
      } else {
        if (nums[count] < min) min = nums[count]
        if (nums[count] > max) max = nums[count]
      }
    }
  }
  END {
    if (count == 0) {
      print "spark: error: no valid numeric data provided" > "/dev/stderr"
      exit 1
    }

    # Constant data: use mid-tier bar for all values
    if (min == max) {
      for (i = 1; i <= count; i++) printf "%s", ticks[5]
      printf "\n"
      exit 0
    }

    range = max - min
    for (i = 1; i <= count; i++) {
      idx = int(((nums[i] - min) * (num_ticks - 1)) / range)
      # Clamp to valid tick range
      if (idx < 0) idx = 0
      if (idx >= num_ticks) idx = num_ticks - 1
      printf "%s", ticks[idx + 1]
    }
    printf "\n"
  }
  '
}

# If we're being sourced, don't worry about such things
if [ "$BASH_SOURCE" == "$0" ]; then
  # Prints the help text for spark.
  help()
  {
    local spark=$(basename $0)
    cat <<EOF

    USAGE:
      $spark [-h|--help] VALUE,...

    DESCRIPTION:
      Generates sparklines from a series of numeric values.
      Values can be separated by commas or spaces (or both).
      Input may also be piped via stdin.

    INPUT FORMAT:
      - Negative numbers are fully supported (e.g. -5, -3.2).
      - Decimal/floating-point numbers are supported (e.g. 0.4, 3.14).
        Decimal precision is preserved so small variations remain visible.
      - Empty fields caused by consecutive delimiters (e.g. "1,,3"),
        leading/trailing delimiters, or extra whitespace are silently
        skipped and do not affect the output.
      - Non-numeric values are skipped with a warning printed to stderr.
      - If no valid numeric data is found, an error is reported and the
        exit code is non-zero.

    EXAMPLES:
      $spark 1 5 22 13 53
      ▁▁▃▂█
      $spark 0,30,55,80,33,150
      ▁▂▃▄▂█
      echo 9 13 5 17 1 | $spark
      ▄▆▂█▁
      $spark -5,-3,-1,0,2
      ▁▃▅▆█
      $spark 0.1,0.5,0.9
      ▁▄█
      $spark 1,,3,,,5
      ▁▄█
EOF
  }

  # show help for no arguments if stdin is a terminal
  if { [ -z "$1" ] && [ -t 0 ] ; } || [ "$1" == '-h' ] || [ "$1" == '--help' ]
  then
    help
    exit 0
  fi

  spark ${@:-`cat`}
fi
