#!/usr/bin/env bash
#
# spark
# https://github.com/holman/spark
#
# Generates sparklines for a set of data.
#
# spark takes a comma-separated, space-separated, or newline-separated list of
# data and then prints a sparkline out of it.
#
# Examples:
#
#   spark 1 5 22 13 53
#   # => ▁▁▃▂▇
#
#   spark 0 30 55 80 33 150
#   # => ▁▂▃▅▂▇
#
#   spark -l CPU 0 30 55 80 33 150
#   # => CPU ▁▂▃▅▂▇
#
#   spark --ascii 0 30 55 80 33 150
#   # => __//\\
#
#   spark -h
#   # => Prints the spark help text.

VERSION="1.1.0"

# Generates sparklines.
#
# $1 - The data we'd like to graph.
_echo()
{
  if [ "X$1" = "X-n" ]; then
    shift
    printf "%s" "$*"
  else
    printf "%s\n" "$*"
  fi
}

# Sanitize input: accept commas, spaces, tabs, and newlines as delimiters.
# Filter out empty and non-numeric tokens. Outputs clean space-separated numbers.
sanitize_input()
{
  local raw="$*"
  # Replace commas and tabs with spaces
  raw="${raw//,/ }"
  raw="${raw//$'\t'/ }"
  # Replace newlines with spaces
  raw="${raw//$'\n'/ }"

  local token
  for token in $raw; do
    # Strip leading/trailing whitespace (already handled by for-loop splitting)
    # Strip decimal portion (bash can't do floats)
    local cleaned="${token%.*}"
    # Skip empty tokens or tokens that aren't integers (allow leading minus)
    if [[ "$cleaned" =~ ^-?[0-9]+$ ]]; then
      _echo -n "$cleaned "
    fi
    # Silently skip non-numeric tokens (dirty data)
  done
}

spark()
{
  local n numbers=

  # find min/max values
  local min=0xffffffff max=0

  for n in $@
  do
    (( n < min )) && min=$n
    (( n > max )) && max=$n
    numbers=$numbers${numbers:+ }$n
  done

  # If no valid numbers, bail out
  if [ -z "$numbers" ]; then
    _echo "(no data)"
    return 1
  fi

  # print ticks
  local ticks
  if [ "$SPARK_ASCII" = "1" ]; then
    ticks=( _ . : - = / \\ '#' '@' )
  else
    ticks=(▁ ▂ ▃ ▄ ▅ ▆ ▇ █)
  fi

  # use a high tick if data is constant
  if [ "$SPARK_ASCII" = "1" ]; then
    (( min == max )) && ticks=( = - )
  else
    (( min == max )) && ticks=(▅ ▆)
  fi

  local f=$(( (($max-$min)<<8)/(${#ticks[@]}-1) ))
  (( f < 1 )) && f=1

  local output=""
  for n in $numbers
  do
    local idx=$(( ((($n-$min)<<8)/$f) ))
    # Clamp index to valid range
    (( idx < 0 )) && idx=0
    (( idx >= ${#ticks[@]} )) && idx=$(( ${#ticks[@]} - 1 ))
    output="${output}${ticks[$idx]}"
  done

  # Build final line
  local line=""

  # Label prefix
  if [ -n "$SPARK_LABEL" ]; then
    line="${SPARK_LABEL} "
  fi

  line="${line}${output}"

  # Separator between sparkline and values
  if [ "$SPARK_SHOW_VALUES" = "1" ]; then
    local sep="${SPARK_SEPARATOR:- | }"
    line="${line}${sep}"
    local first=1
    for n in $numbers
    do
      if [ "$first" = "1" ]; then
        line="${line}${n}"
        first=0
      else
        line="${line} ${n}"
      fi
    done
  fi

  _echo "$line"
}

# If we're being sourced, don't worry about such things
if [ "$BASH_SOURCE" == "$0" ]; then
  # Prints the help text for spark.
  help()
  {
    local spark=$(basename $0)
    cat <<EOF

    USAGE:
      $spark [OPTIONS] VALUE,...

    OPTIONS:
      -l, --label LABEL    Prefix output with LABEL (e.g. metric name)
      -a, --ascii          Use ASCII characters instead of Unicode blocks
      -v, --values         Show raw numeric values after the sparkline
      -s, --separator SEP  Separator between sparkline and values (default: " | ")
      -h, --help           Show this help text
          --version        Show version

    EXAMPLES:
      $spark 1 5 22 13 5
      ▁▂█▅▂

      $spark 0,30,55,80,33,150
      ▁▂▃▄▂█

      echo 9 13 5 17 1 | $spark
      ▄▆▂█▁

      $spark -l CPU 10 20 30 40 50
      CPU ▁▂▄▆█

      $spark --ascii 0 30 55 80 33 150
      _.:=.@

      $spark -l MEM -v 1024 2048 512 4096
      MEM ▂▄▁█ | 1024 2048 512 4096

      $spark -l DISK --ascii -v 80 90 70 95
      DISK -\_@ | 80 90 70 95

    PIPELINE USAGE:
      # From a pipe with mixed delimiters:
      echo "1,2 3,4 5" | $spark
      ▁▂▄▆█

      # Multi-line input (one value per line):
      printf "10\n20\n30\n" | $spark -l LOAD
      LOAD ▁▄█

      # Dirty data (non-numeric values are silently skipped):
      echo "1,N/A,3,--,5" | $spark
      ▁▄█

      # Inspection report style:
      for metric in "CPU:10,20,50,80,95" "MEM:1024,2048,512,4096,2048"; do
        name=\${metric%%:*}
        data=\${metric#*:}
        $spark -l \$name \$data
      done
      CPU ▁▂▄▆█
      MEM ▂▄▁█▄

    ASCII FALLBACK:
      Use --ascii when your terminal or font does not render Unicode block
      characters correctly. ASCII mode uses: _ . : - = / \\ # @
EOF
  }

  # Parse options
  SPARK_LABEL=""
  SPARK_ASCII=0
  SPARK_SHOW_VALUES=0
  SPARK_SEPARATOR=" | "
  SPARK_ARGS=()

  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help)
        help
        exit 0
        ;;
      --version)
        _echo "spark $VERSION"
        exit 0
        ;;
      -l|--label)
        shift
        SPARK_LABEL="$1"
        shift
        ;;
      -a|--ascii)
        SPARK_ASCII=1
        shift
        ;;
      -v|--values)
        SPARK_SHOW_VALUES=1
        shift
        ;;
      -s|--separator)
        shift
        SPARK_SEPARATOR="$1"
        shift
        ;;
      *)
        SPARK_ARGS+=("$1")
        shift
        ;;
    esac
  done

  # show help for no arguments if stdin is a terminal
  if { [ ${#SPARK_ARGS[@]} -eq 0 ] && [ -t 0 ] ; }
  then
    help
    exit 0
  fi

  # Collect input from args or stdin
  local_input=""
  if [ ${#SPARK_ARGS[@]} -gt 0 ]; then
    local_input="${SPARK_ARGS[*]}"
  else
    local_input="$(cat)"
  fi

  # Sanitize and run
  clean=$(sanitize_input $local_input)
  spark $clean
fi
